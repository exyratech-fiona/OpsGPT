# Copy to .env (or run ./setup.sh which generates it for you) and edit.

# --- the GGUF filenames in ./models (set these to YOUR actual filenames) ---
MODEL_FILE=Qwen3-8B-Q4_K_M.gguf
EMBED_MODEL_FILE=nomic-embed-text-v1.5.f16.gguf

# --- performance (M4 has ~10 cores; 8 is a good default) ---
LLAMA_THREADS=8
LLAMA_CTX=8192

# --- API port on your Mac (Swagger + /v1) ---
API_PORT=8000

# --- secrets (setup.sh generates strong values automatically) ---
OPSGPT_JWT_SECRET=CHANGE_ME_run_setup_sh
OPSGPT_ADMIN_EMAIL=admin@opsgpt.local
OPSGPT_ADMIN_PASSWORD=CHANGE_ME_run_setup_sh

# --- database (fine as-is for a local demo) ---
POSTGRES_USER=opsgpt
POSTGRES_PASSWORD=opsgpt
POSTGRES_DB=opsgpt
