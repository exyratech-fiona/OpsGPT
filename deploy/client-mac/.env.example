# Copy to .env (or run ./setup.sh) and edit.

# --- Docker Hub account the images were pushed to (REQUIRED) ---
DOCKERHUB_USER=your-dockerhub-username
IMAGE_TAG=mac

# --- the GGUF filenames in ./models (set to YOUR actual filenames) ---
MODEL_FILE=Qwen3-8B-Q4_K_M.gguf
EMBED_MODEL_FILE=nomic-embed-text-v1.5.f16.gguf

# --- performance (M4 ~10 cores) ---
LLAMA_THREADS=8
LLAMA_CTX=8192

# --- API port on the Mac (Swagger + /v1) ---
API_PORT=8000

# --- secrets (setup.sh fills strong values automatically) ---
OPSGPT_JWT_SECRET=CHANGE_ME_run_setup_sh
OPSGPT_ADMIN_EMAIL=admin@opsgpt.local
OPSGPT_ADMIN_PASSWORD=CHANGE_ME_run_setup_sh

# --- database (fine as-is for a local demo) ---
POSTGRES_USER=opsgpt
POSTGRES_PASSWORD=opsgpt
POSTGRES_DB=opsgpt
