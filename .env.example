# ============================================================
#  OpsGPT — environment configuration
#  Copy to .env and edit.  `docker compose` reads .env automatically.
#  Anything with a compose default (${VAR:-default}) is optional here.
#  >>> CHANGE every value marked  CHANGE-ME  before going live. <<<
# ============================================================

# ---- Web UI / edge port on the host ----
HTTP_PORT=8088

# ---- Models (files must exist in ./models — see scripts/download_models.sh) ----
MODEL_FILE=Qwen_Qwen3-8B-Q4_K_M.gguf
MODEL_ALIAS=qwen3-8b
PHI_MODEL_FILE=Phi-4-mini-instruct-Q4_K_M.gguf
XCODER_MODEL_FILE=X-Coder-RL-Qwen3-8B.i1-Q4_K_M.gguf
EMBED_MODEL_FILE=nomic-embed-text-v1.5.f16.gguf
EMBED_BGE_MODEL_FILE=bge-large-en-v1.5-f16.gguf
RERANKER_MODEL_FILE=bge-reranker-v2-m3-Q8_0.gguf

# ---- llama.cpp CPU tuning (defaults tuned for dual-socket Xeon, no GPU) ----
# Memory-bandwidth-bound. Interleaving across both NUMA nodes is the big win.
LLAMA_CTX=8192
LLAMA_THREADS=20
LLAMA_PARALLEL=2
LLAMA_NUMA=distribute
LLAMA_CPUSET=0-19

# ---- Backend ----
OPSGPT_ENVIRONMENT=production
OPSGPT_LOG_LEVEL=info
# Comma-separated origins the browser uses (scheme://host:port)
OPSGPT_CORS_ORIGINS=http://localhost:8088

# ---- PostgreSQL ----
POSTGRES_USER=opsgpt
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=opsgpt

# ---- Auth / JWT ----
# MUST be a long random string. Generate: openssl rand -hex 32
OPSGPT_JWT_SECRET=CHANGE-ME-run-openssl-rand-hex-32
OPSGPT_ACCESS_TOKEN_TTL_MIN=30
OPSGPT_REFRESH_TOKEN_TTL_DAYS=7
# Seed admin, created only on first run when the users table is empty:
OPSGPT_ADMIN_EMAIL=admin@opsgpt.local
OPSGPT_ADMIN_PASSWORD=CHANGE-ME-first-admin-password

# ---- Redis (rate-limit + caches; fails open if down) ----
OPSGPT_RATE_LIMIT_PER_MIN=20

# ---- Elasticsearch MCP (optional — leave blank to disable) ----
OPSGPT_ES_URL=
OPSGPT_ES_USERNAME=
OPSGPT_ES_PASSWORD=
OPSGPT_ES_VERIFY_TLS=false

# ---- Backups (postgres pg_dump sidecar) ----
BACKUP_INTERVAL_HOURS=24
BACKUP_RETAIN_DAYS=7

# ---- Monitoring ----
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-grafana-password

# ---- Kubernetes / GitLab MCP ----
# These are configured at runtime in the UI (Tool Connections panel), not here.
# For Kubernetes you may drop a read-only kubeconfig at ./secrets/kube-readonly.yaml
